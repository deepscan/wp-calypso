{
	"name": "@automattic/odie-client",
	"version": "1.1.0",
	"description": "Odie client to chat with bots.",
	"homepage": "https://github.com/Automattic/wp-calypso",
	"license": "GPL-2.0-or-later",
	"author": "Automattic Inc.",
	"main": "dist/cjs/index.js",
	"module": "dist/esm/index.js",
	"calypso:src": "src/index.tsx",
	"exports": {
		".": {
			"calypso:src": "./src/index.tsx",
			"types": "./dist/types/index.d.ts",
			"import": "./dist/esm/index.js",
			"require": "./dist/cjs/index.js"
		},
		"./src/*": {
			"calypso:src": "./src/*"
		}
	},
	"sideEffects": [
		"*.css",
		"*.scss"
	],
	"repository": {
		"type": "git",
		"url": "git+https://github.com/Automattic/wp-calypso.git",
		"directory": "packages/odie-client"
	},
	"publishConfig": {
		"access": "public"
	},
	"bugs": "https://github.com/Automattic/wp-calypso/issues",
	"types": "dist/types",
	"scripts": {
		"clean": "tsc --build ./tsconfig.json ./tsconfig-cjs.json --clean && rm -rf dist",
		"build": "tsc --build ./tsconfig.json ./tsconfig-cjs.json && yarn run -T copy-assets",
		"prepack": "yarn run clean && yarn run build",
		"test": "yarn jest",
		"watch": "tsc --build ./tsconfig.json --watch"
	},
	"dependencies": {
		"@automattic/agenttic-ui": "^0.1.80",
		"@automattic/calypso-analytics": "workspace:^",
		"@automattic/components": "workspace:^",
		"@automattic/data-stores": "workspace:^",
		"@automattic/i18n-utils": "workspace:^",
		"@automattic/urls": "workspace:^",
		"@automattic/zendesk-client": "workspace:^",
		"@tanstack/react-query": "^5.83.0",
		"@wordpress/api-fetch": "7.48.0",
		"@wordpress/components": "^35.0.0",
		"@wordpress/data": "^10.48.0",
		"@wordpress/element": "^8.0.0",
		"@wordpress/html-entities": "^4.48.0",
		"@wordpress/i18n": "^6.21.0",
		"@wordpress/icons": "^13.3.0",
		"@wordpress/react-i18n": "^4.48.0",
		"@wordpress/url": "^4.48.0",
		"autosize": "^6.0.1",
		"classnames": "^2.5.1",
		"clsx": "^2.1.1",
		"dompurify": "3.4.12",
		"framer-motion": "^12.23.12",
		"react-intersection-observer": "^9.4.3",
		"react-markdown": "^9.0.1",
		"react-redux": "^9.2.0",
		"react-router-dom": "6.30.4",
		"smooch": "^5.7.17",
		"tslib": "^2.8.1",
		"wpcom-proxy-request": "^7.0.5"
	},
	"peerDependencies": {
		"react": "^18.3.1 || ^19.0.0",
		"react-dom": "^18.3.1 || ^19.0.0"
	},
	"devDependencies": {
		"@automattic/calypso-typescript-config": "workspace:^",
		"@testing-library/jest-dom": "^6.9.1",
		"@types/autosize": "^4.0.3",
		"@types/jest": "^29.5.14",
		"@types/react": "^18.3.23",
		"@types/smooch": "^5.6.0",
		"jest": "^29.7.0",
		"react": "^18.3.1",
		"react-dom": "^18.3.1",
		"typescript": "^6.0.3"
	}
}
